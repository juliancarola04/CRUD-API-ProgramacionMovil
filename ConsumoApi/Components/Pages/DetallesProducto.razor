@* En esta página podremos mostrar los detalles de un producto obtenido a través de los parámetros. Se accede acá a través del listado de productos *@

@page "/detalleproducto/{id:int}"
@inject HttpClient _http
@inject NavigationManager _navigationManager

@if (estaCargando)
{
    <p>Cargando el producto...</p>
} else if (huboError) @* Si no pudo encontrarlo o el endpoint está mal *@
{
    <p>@mensaje</p>
} else
{
    @* Muestro todos los detalles dle producto en cuestión *@
    <div class="container">
        <div class="row">
            <div class="col-lg-auto col-sm-auto">
                <div class="card mb-3">
                    <div class="row">
                        <div class="col-4">
                            <img src="@producto.image" class="img-fluid rounded-start" alt="Imagen del producto @producto.title">
                        </div>
                        <div class="col-8">
                            <div class="card-body h-100">
                                <h5 class="card-title">@producto.title</h5>
                                <p class="card-text">@producto.description</p>
                                <p class="card-text">Precio: $@producto.price</p>
                                <p class="card-text">Categoria: @producto.category</p>
                                <p class="card-text">Puntaje de reseña: @producto.rating.rate</p>
                                <p class="card-text">Número de reseñas: @producto.rating.count</p>
                            </div>
                        </div>
                        <button class="btn btn-success mt-3" @onclick="volverListaProductos">Volver</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public int id { get; set; }

    private Producto producto = new();
    private bool estaCargando = false;
    private bool huboError = false;
    private string? mensaje;

    protected override async Task OnParametersSetAsync()
    {
        estaCargando = true;
        var response = await _http.GetAsync($"products/{id}");
        try
        {
            response.EnsureSuccessStatusCode(); @* Si falla tira excepción. *@
            producto = await response.Content.ReadFromJsonAsync<Producto>();
            huboError = false;
        }
        catch (HttpRequestException ex)
        {
            huboError = true;
            mensaje = $"Hubo un error recuperando el producto. Error código: {response.StatusCode}";
        }
        estaCargando = false;
    }

    private void volverListaProductos()
    {
        _navigationManager.NavigateTo("/listaProductos");
    }
}
