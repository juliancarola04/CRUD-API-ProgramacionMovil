@page "/listaProductos"
@inject HttpClient _http
@inject NavigationManager _navigationManager

@if (estaCargando)
{
    <p>Cargando la lista de productos...</p>
} else
{
    if (huboError)
    {
        <p>@mensaje</p>

    } else if (productos.Count == 0)
    {
        <p>No se encontraron productos.</p>
    } else {
        <div class="container">
            @if (mostrarModal)
            {
                <div class="modal fade show d-block" tabindex="-1">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">Eliminar producto</h5>
                                <button type="button"
                                        class="btn-close"
                                        @onclick="ocultarModalEliminar">
                                </button>
                            </div>

                            <div class="modal-body">
                                <p>¿Te encuentras seguro de que deseas eliminar el producto?</p>
                            </div>

                            <div class="modal-footer">
                                <button class="btn btn-secondary"
                                        @onclick="ocultarModalEliminar">
                                    Cancelar
                                </button>

                                <button class="btn btn-danger"
                                        @onclick="() => eliminarProducto(idProductoEliminar)">
                                    Eliminar
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal-backdrop fade show"></div>
            }
            <div class="d-flex justify-content-center mb-3">
                <button class="btn btn-success" @onclick="agregarProducto">Agregar producto</button>
            </div>
            <div class="row">
                @foreach (Producto producto in productos)
                {
                    <div class="col-lg-6 col-sm-auto">
                        <div class="card mb-3">
                            <div class="row">
                                <div class="col-4">
                                    <img src="@producto.image" class="img-fluid rounded-start" alt="Imagen del producto @producto.title">
                                </div>
                                <div class="col-8">
                                    <div class="card-body h-100">
                                        <h5 class="card-title">@producto.title</h5>
                                        <p class="card-text">@producto.description</p>
                                        <button class="btn btn-primary" @onclick="() => modificarProducto(producto.id)">Modificar</button>
                                        <button class="btn btn-danger" @onclick="() => mostrarModalEliminar(producto.id)">Eliminar</button>
                                        <button class="btn btn-success" @onclick="() => mostrarDetalles(producto.id)">Detalles</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }    
}

@code {
    private List<Producto> productos = new();
    private bool estaCargando = true;
    private bool huboError = false;
    private bool mostrarModal = false;
    private int idProductoEliminar = 0;

    private string? mensaje;


    protected override async Task OnInitializedAsync()
    {
        estaCargando = true;
        var response = await _http.GetAsync("products");
        try
        {
            response.EnsureSuccessStatusCode();
            productos = await response.Content.ReadFromJsonAsync<List<Producto>>();
            huboError = false;
        }
        catch (HttpRequestException ex)
        {
            huboError = true;
            mensaje = $"Hubo un error recupernado los productos. Error código: {response.StatusCode}";
        }
        estaCargando = false;
    }

    private void modificarProducto(int id)
    {
        _navigationManager.NavigateTo($"/modificarproducto/{id}");
    }

    private void agregarProducto()
    {
        _navigationManager.NavigateTo("/agregarproducto");
    }

    private void mostrarModalEliminar(int id)
    {
        idProductoEliminar = id;
        mostrarModal = true;
    }

    private void ocultarModalEliminar()
    {
        idProductoEliminar = 0;
        mostrarModal = false;
    }

    private async Task eliminarProducto(int id)
    {
        HttpResponseMessage response = await _http.DeleteAsync($"products/{id}");
        try
        {
            response.EnsureSuccessStatusCode();
            productos.RemoveAll(x => x.id == id);
        }
        catch (HttpRequestException ex)
        {
            huboError = true;
            mensaje = $"Hubo un error eliminando los productos. Error código: {response.StatusCode}";
        }

        ocultarModalEliminar();

    }
    private void mostrarDetalles(int id)
    {
        _navigationManager.NavigateTo($"/detalleproducto/{id}");
    }
}

